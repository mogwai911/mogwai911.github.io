---
import type { Lang } from '../data/content';

interface Props {
  lang: Lang;
  alternatePath: string;
  compact?: boolean;
}

const { lang, alternatePath, compact = false } = Astro.props;
const isZh = lang === 'zh';
const home = isZh ? '/' : '/en/';
const work = isZh ? '/work/' : '/en/work/';
const sideProjects = isZh ? '/hobbies/' : '/en/hobbies/';
const about = isZh ? '/about/' : '/en/about/';
const path = Astro.url.pathname;
const section = path.includes('/projects/') || path.includes('/work/')
  ? 'work'
  : path.includes('/hobbies/')
    ? 'side-projects'
    : path.includes('/about/') || path.includes('/f1/')
      ? 'about'
      : 'home';

const navigation = [
  { id: 'work', href: work, label: isZh ? '作品' : 'Work' },
  { id: 'side-projects', href: sideProjects, label: isZh ? '兴趣制作' : 'Side projects' },
  { id: 'about', href: about, label: isZh ? '关于' : 'About' },
];
---

<header class:list={['site-header', { 'site-header--compact': compact }]}>
  <div class="site-header__inner">
    <a class="site-identity" href={home} aria-label={isZh ? 'Kylian 个人网站首页' : 'Kylian personal site home'}>
      <strong>Kylian</strong>
      <span>{isZh ? '个人网站' : 'Personal site'}</span>
    </a>

    <nav class="desktop-nav" aria-label={isZh ? '主导航' : 'Primary navigation'}>
      {navigation.map((item) => (
        <a href={item.href} aria-current={section === item.id ? 'page' : undefined}>{item.label}</a>
      ))}
    </nav>

    <div class="header-tools">
      <a href="https://x.com/icewaterdundun" target="_blank" rel="noreferrer" aria-label="Kylian on X">X</a>
      <a class="language-link" href={alternatePath} lang={isZh ? 'en' : 'zh-CN'} hreflang={isZh ? 'en' : 'zh-CN'}>{isZh ? 'EN' : '中文'}</a>
      <button class="mobile-menu-trigger" type="button" aria-controls="mobile-navigation" aria-expanded="false">
        <span>{isZh ? '菜单' : 'Menu'}</span><i aria-hidden="true"></i>
      </button>
    </div>
  </div>

  <nav class="mobile-nav" id="mobile-navigation" aria-hidden="true" aria-label={isZh ? '移动端导航' : 'Mobile navigation'}>
    <a href={home} aria-current={section === 'home' ? 'page' : undefined}>{isZh ? '首页' : 'Home'}</a>
    {navigation.map((item) => (
      <a href={item.href} aria-current={section === item.id ? 'page' : undefined}>{item.label}</a>
    ))}
    <a href="mailto:icewaterdundundun@gmail.com">Email</a>
  </nav>
</header>
