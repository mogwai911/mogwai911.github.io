---
import type { Lang, ProjectCase } from '../data/content';
import { projects } from '../data/content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BusinessFlow from './BusinessFlow.astro';
import SiteHeader from './SiteHeader.astro';

interface Props { lang: Lang; project: ProjectCase }
const { lang, project } = Astro.props;
const isZh = lang === 'zh';
const projectBase = isZh ? '/projects' : '/en/projects';
const workPath = isZh ? '/work/' : '/en/work/';
const sidePath = isZh ? '/hobbies/' : '/en/hobbies/';
const canonicalPath = `${projectBase}/${project.slug}/`;
const alternatePath = `${isZh ? '/en/projects' : '/projects'}/${project.slug}/`;
const isSideProject = project.slug === 'aigc-pov';
const workProjects = projects.filter((item) => item.slug !== 'aigc-pov');
const projectIndex = workProjects.findIndex((item) => item.slug === project.slug);
const nextProject = isSideProject ? undefined : workProjects[(projectIndex + 1) % workProjects.length];
const parentPath = isSideProject ? sidePath : workPath;
---

<BaseLayout lang={lang} title={`${project.displayTitle[lang]} | ${project.title} — Kylian`} description={project.summary[lang]} canonicalPath={canonicalPath} alternatePath={alternatePath}>
  <div class="site-shell case-shell">
    <SiteHeader lang={lang} alternatePath={alternatePath} compact />
    <main id="content" class="case-story">
      <header class="case-story__hero content-width" data-reveal>
        <p class="section-label">{isSideProject ? (isZh ? '兴趣制作' : 'Side project') : (isZh ? '项目记录' : 'Project note')} · {project.year}</p>
        <h1>{project.displayTitle[lang]}</h1>
        <p class="case-story__codename">{project.title}</p>
        <p class="case-story__deck">{project.summary[lang]}</p>
        <ul class="tag-list">{project.tags.map((tag) => <li>{tag}</li>)}</ul>
      </header>

      <section class="case-opening content-width" data-reveal>
        <div>
          <p class="section-label">{isZh ? '为什么会做这件事' : 'Why I started'}</p>
          <h2>{project.why[lang]}</h2>
        </div>
        <aside>
          <span>{isZh ? '我负责的部分' : 'My part'}</span>
          <p>{project.role[lang]}</p>
          {(project.link || project.video) && <div class="case-external-links">
            {project.video && <a class="button-link" href={project.video.url} target="_blank" rel="noreferrer" title={project.video.title[lang]}>{isZh ? '在 Bilibili 看成片' : 'Watch the finished film'} <span>↗</span></a>}
            {project.link && <a class="quiet-link" href={project.link} target="_blank" rel="noreferrer">{isZh ? '查看公开仓库' : 'View public repository'} <span>↗</span></a>}
          </div>}
        </aside>
      </section>

      {project.images?.[0] && (
        <figure class="case-image case-image--lead content-width" data-reveal>
          <a href={project.images[0].src} target="_blank" rel="noreferrer" aria-label={`${isZh ? '打开原尺寸图片' : 'Open full-size image'}: ${project.images[0].alt[lang]}`}>
            <img src={project.images[0].src} alt={project.images[0].alt[lang]} width="1600" height="900" />
          </a>
          <figcaption><span>{isZh ? '点击查看原图' : 'Open full size'}</span>{project.images[0].alt[lang]}</figcaption>
        </figure>
      )}

      <section class="case-question content-width" data-reveal>
        <p class="section-label">{isZh ? '真正的问题' : 'The real question'}</p>
        <blockquote>{project.question[lang]}</blockquote>
      </section>

      <section class="case-decisions content-width" data-reveal>
        <header><p class="section-label">{isZh ? '我做的关键选择' : 'Choices I made'}</p><h2>{isZh ? '每个动作，都应该能解释为什么。' : 'Every action should have a reason.'}</h2></header>
        <ol>
          {project.decisions[lang].map((decision) => <li><h3>{decision.action}</h3><p>{decision.reason}</p></li>)}
        </ol>
      </section>

      <section class="case-flow content-width" data-reveal>
        <header><p class="section-label">{isZh ? '系统怎样运转' : 'How the system moves'}</p><h2>{project.workflow[lang].heading}</h2></header>
        <BusinessFlow lang={lang} flow={project.workflow[lang]} />
      </section>

      <section class="case-making content-width" data-reveal>
        <header><p class="section-label">{isZh ? '亲手做的部分' : 'What I made'}</p><h2>{isZh ? '从判断到可运行的东西。' : 'From judgment to something that runs.'}</h2></header>
        <div>{project.process[lang].map((step) => <article><h3>{step.title}</h3><p>{step.text}</p></article>)}</div>
      </section>

      {project.images && project.images.length > 1 && (
        <section class="case-gallery content-width" aria-label={isZh ? '项目界面' : 'Project interfaces'}>
          {project.images.slice(1).map((image) => <figure data-reveal><a href={image.src} target="_blank" rel="noreferrer" aria-label={`${isZh ? '打开原尺寸图片' : 'Open full-size image'}: ${image.alt[lang]}`}><img src={image.src} alt={image.alt[lang]} width="1600" height="900" loading="lazy" /></a><figcaption><span>{isZh ? '点击查看原图' : 'Open full size'}</span>{image.alt[lang]}</figcaption></figure>)}
        </section>
      )}

      <section class="case-ending content-width" data-reveal>
        <div class="case-evidence">
          <p class="section-label">{isZh ? '留下的证据' : 'What the work left behind'}</p>
          <ul>{project.evidence[lang].map((item) => <li>{item}</li>)}</ul>
        </div>
        <div class="case-limits">
          <article><span>{isZh ? '现在还不能证明' : 'What this does not prove yet'}</span><p>{project.boundary[lang]}</p></article>
          <article><span>{isZh ? '下一次会验证' : 'What I would test next'}</span><p>{project.next[lang]}</p></article>
        </div>
      </section>

      <nav class="case-navigation content-width" aria-label={isZh ? '案例导航' : 'Case study navigation'}>
        <a href={parentPath}>← {isSideProject ? (isZh ? '兴趣制作' : 'Side projects') : (isZh ? '全部作品' : 'All work')}</a>
        {nextProject && <a href={`${projectBase}/${nextProject.slug}/`}><span>{isZh ? '接着看' : 'Next story'}</span>{nextProject.displayTitle[lang]} →</a>}
      </nav>
    </main>
    <footer class="site-footer content-width"><p>© {new Date().getFullYear()} Kylian</p><p>{project.title}</p><a href="#content">{isZh ? '回到顶部' : 'Back to top'} ↑</a></footer>
  </div>
</BaseLayout>
