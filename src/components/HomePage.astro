---
import type { Lang } from '../data/content';
import { profile, projects } from '../data/content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from './SiteHeader.astro';

interface Props { lang: Lang }
const { lang } = Astro.props;
const isZh = lang === 'zh';
const home = isZh ? '/' : '/en/';
const workPath = isZh ? '/work/' : '/en/work/';
const aboutPath = isZh ? '/about/' : '/en/about/';
const sidePath = isZh ? '/hobbies/' : '/en/hobbies/';
const projectBase = isZh ? '/projects' : '/en/projects';
const alternate = isZh ? '/en/' : '/';
const title = isZh ? 'Kylian — AI 应用、Agent 评测与 GIS' : 'Kylian — AI applications, agent evaluation, and GIS';
const description = profile.intro[lang];
const workOrder = ['tb2-diagnostics', 'fomo-firewall', 'geoagent'];
const selected = workOrder.map((slug) => projects.find((project) => project.slug === slug)).filter(Boolean);
const posterLabels = {
  'tb2-diagnostics': ['TRACE', 'CAUSE', 'FIX'],
  'fomo-firewall': ['LEARN', 'LATER', 'IGNORE'],
  'geoagent': ['SEARCH', 'RUN', 'VERIFY'],
};
---

<BaseLayout lang={lang} title={title} description={description} canonicalPath={home} alternatePath={alternate}>
  <div class="site-shell home-shell">
    <SiteHeader lang={lang} alternatePath={alternate} />
    <main id="content">
      <section class="home-hero" aria-labelledby="hero-title">
        <figure class="home-hero__photo" data-photo-drift>
          <picture>
            <source media="(max-width: 720px)" srcset="/images/vienna-hero-960.webp" />
            <img src="/images/vienna-hero-1800.webp" alt={isZh ? 'Kylian 在金色大厅中侧身看向右方' : 'Kylian looking to the right inside a golden hall'} width="1800" height="1200" fetchpriority="high" />
          </picture>
          <figcaption>{isZh ? '维也纳，一次没有预设答案的停留' : 'Vienna, a pause without a predetermined answer'}</figcaption>
        </figure>

        <div class="home-hero__shade" aria-hidden="true"></div>
        <div class="home-hero__copy" data-reveal>
          <p class="eyebrow">Kylian · Personal site</p>
          <h1 id="hero-title">{isZh ? <>堆叠可能性，<br /><em>而非追寻确定性。</em></> : <>Stack possibilities.<br /><em>Do not chase certainty.</em></>}</h1>
          <p class="home-hero__role">AI {isZh ? '应用落地' : 'applications'} · Agent {isZh ? '评测' : 'evaluation'} · GIS</p>
          <p class="home-hero__intro">{isZh ? '我从空间数据出发，现在关注 AI 如何进入真实工作：哪里值得介入、系统为什么失效，以及怎样用一次可验证的改动让它变好。' : 'I started with spatial data and now focus on how AI enters real work: where intervention matters, why a system fails, and how one verifiable change can make it better.'}</p>
          <div class="hero-links">
            <a class="button-link button-link--light" href={workPath}>{isZh ? '看看我做过什么' : 'See what I have made'} <span>↗</span></a>
            <a class="quiet-link quiet-link--light" href={aboutPath}>{isZh ? '先认识我' : 'Meet Kylian'} <span>→</span></a>
          </div>
        </div>

        <p class="home-hero__note" aria-hidden="true">observe · unfold · make</p>
      </section>

      <section class="home-now content-width" data-reveal>
        <p class="section-label">{isZh ? '现在 / NOW' : 'NOW'}</p>
        <div>
          <h2>{isZh ? <>从 GIS 到 Agent，<br />我总想先看清系统怎么运转。</> : <>From GIS to agents,<br />I first want to see how the system moves.</>}</h2>
          <p>{isZh ? '信息很多、系统很复杂，但真正需要被看清的通常只有几件事：哪一步出了问题，谁会受到影响，以及下一步能不能被实际执行。比起先给自己贴一个职业标签，我更愿意用做出来的东西回答。' : 'There is always too much information and too much system complexity. What matters is usually smaller: where it broke, who is affected, and whether the next step can actually be carried out. I would rather answer with things I have made than start with a job-title label.'}</p>
        </div>
      </section>

      <section class="home-work content-width" aria-labelledby="home-work-title">
        <header class="editorial-heading" data-reveal>
          <p class="section-label">Selected work</p>
          <h2 id="home-work-title">{isZh ? '最近，我在这些问题里停留得比较久。' : 'These are the problems I have stayed with lately.'}</h2>
          <a class="quiet-link" href={workPath}>{isZh ? '查看全部作品' : 'View all work'} <span>→</span></a>
        </header>

        <div class="project-stories">
          {selected.map((project) => project && (
            <a class={`project-story project-story--${project.slug}`} href={`${projectBase}/${project.slug}/`} data-reveal>
              <div class="project-poster" aria-hidden="true">
                <div class="poster-grain"></div>
                <span class="poster-code">{project.title}</span>
                <div class="poster-orbit"><i></i><i></i><i></i></div>
                <div class="poster-words">
                  {(posterLabels[project.slug as keyof typeof posterLabels] ?? []).map((word) => <span>{word}</span>)}
                </div>
              </div>
              <div class="project-story__copy">
                <p>{project.eyebrow[lang]} · {project.year}</p>
                <h3>{project.displayTitle[lang]}</h3>
                <p>{project.summary[lang]}</p>
                <span>{isZh ? '进入这个故事' : 'Open the story'} ↗</span>
              </div>
            </a>
          ))}
        </div>
      </section>

      <section class="home-side content-width" data-reveal>
        <div class="home-side__image">
          <img src="/images/aigc-pov.webp" alt={isZh ? 'AIGC 多镜头 POV 创作画面' : 'A frame from a multi-shot AIGC POV experiment'} width="1600" height="900" loading="lazy" />
          <span>{isZh ? '制作中的一帧' : 'A frame in the making'}</span>
        </div>
        <div class="home-side__copy">
          <p class="section-label">Made by curiosity</p>
          <h2>{isZh ? '不是所有东西，都要先证明它有用。' : 'Not everything needs to prove its utility first.'}</h2>
          <p>{isZh ? '我也会做 AIGC 影像和一只会孵化的 Codex 桌宠。它们不属于职业主线，但很能说明我为什么喜欢把想法变成可以观看、运行或陪伴的东西。' : 'I also make AIGC film experiments and a hatchable Codex desktop pet. They are not part of the career narrative, but they show why I like turning ideas into things that can be watched, run, or kept nearby.'}</p>
          <a class="button-link" href={sidePath}>{isZh ? '去看兴趣制作' : 'See side projects'} <span>↗</span></a>
        </div>
      </section>

      <section class="home-about content-width" data-reveal>
        <div>
          <p class="section-label">About</p>
          <h2>{isZh ? '我喜欢复杂系统，但更喜欢把它讲明白。' : 'I like complex systems. I like making them understandable even more.'}</h2>
        </div>
        <div>
          <p>{isZh ? '教育背景、真实经历、F1 观察，以及我现在愿意公开的联系方式，都放在 About。' : 'My education, field experience, F1 notes, and public contact details live in About.'}</p>
          <a class="quiet-link" href={aboutPath}>{isZh ? '关于 Kylian' : 'About Kylian'} <span>→</span></a>
        </div>
      </section>

      <section class="contact-note content-width" data-reveal>
        <p>{isZh ? '如果你正在处理一个还没有被说清的问题，我们可以聊聊。' : 'If you are working on a problem that has not been made clear yet, we can talk.'}</p>
        <div><a href={`mailto:${profile.email}`}>{profile.email}</a><a href={profile.x.url} target="_blank" rel="noreferrer">X · {profile.x.label}</a></div>
      </section>
    </main>

    <footer class="site-footer content-width">
      <p>© {new Date().getFullYear()} Kylian</p>
      <p>{isZh ? '观察 · 拆开 · 做出来' : 'Observe · Unfold · Make'}</p>
      <a href="#content">{isZh ? '回到顶部' : 'Back to top'} ↑</a>
    </footer>
  </div>
</BaseLayout>
