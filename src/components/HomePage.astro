---
import type { Lang } from '../data/content';
import { profile, projects, timeline } from '../data/content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from './SiteHeader.astro';

interface Props { lang: Lang }
const { lang } = Astro.props;
const isZh = lang === 'zh';
const home = isZh ? '/' : '/en/';
const workPath = isZh ? '/work/' : '/en/work/';
const aboutPath = isZh ? '/about/' : '/en/about/';
const interestsPath = isZh ? '/hobbies/' : '/en/hobbies/';
const projectBase = isZh ? '/projects' : '/en/projects';
const alternate = isZh ? '/en/' : '/';
const title = isZh ? 'Kylian — AI 应用、评测与工作流' : 'Kylian — AI applications, evaluation, and workflows';
const description = profile.intro[lang];
const workOrder = ['tb2-diagnostics', 'fomo-firewall', 'geoagent'];
const selected = workOrder.map((slug) => projects.find((project) => project.slug === slug)).filter(Boolean);
const experience = timeline.experience[0];
---

<BaseLayout lang={lang} title={title} description={description} canonicalPath={home} alternatePath={alternate}>
  <div class="v3-page-shell">
    <SiteHeader lang={lang} alternatePath={alternate} />
    <main id="content">
      <section class="v3-home-hero" aria-labelledby="hero-title">
        <figure class="v3-hero-photo" data-reveal>
          <picture>
            <source media="(max-width: 720px)" srcset="/images/vienna-hero-960.webp" />
            <img src="/images/vienna-hero-1800.webp" alt={isZh ? 'Kylian 在金色大厅中侧身看向右方' : 'Kylian looking to the right inside a golden hall'} width="1800" height="1200" fetchpriority="high" />
          </picture>
          <figcaption><span>Personal frame / 2024</span><b>{isZh ? '观察与行动之间' : 'Between observation and action'}</b></figcaption>
        </figure>

        <div class="v3-hero-copy" data-reveal>
          <div class="v3-issue-line"><span>Vol. 01</span><i></i><b>Portfolio · 2026</b></div>
          <p class="v3-kicker">AI {isZh ? '应用落地' : 'applications'} · Agent {isZh ? '评测' : 'evaluation'} · GIS</p>
          <p class="v3-hero-name">Kylian</p>
          <h1 id="hero-title">{isZh ? <>判断什么值得做，<br /><em>然后把它做出来。</em></> : <>Decide what is worth doing.<br /><em>Then make it real.</em></>}</h1>
          <p class="v3-hero-intro">{profile.intro[lang]}</p>
          <div class="v3-hero-actions">
            <a class="v3-primary-action" href={workPath}>{isZh ? '查看我具体做过什么' : 'See what I have built'} <span>↗</span></a>
            <a class="v3-text-action" href={aboutPath}>{isZh ? '认识 Kylian' : 'About Kylian'} →</a>
          </div>
        </div>

        <aside class="v3-value-formula" data-reveal aria-label={isZh ? '产品判断公式' : 'Product judgment formula'}>
          <span>{isZh ? '我的判断起点' : 'My starting point'}</span>
          <p>{isZh ? '是否值得做' : 'Worth doing?'}</p>
          <b>=</b>
          <p>{isZh ? '预期影响' : 'Expected impact'}</p>
          <b>×</b>
          <p>{isZh ? '可干预性' : 'Ability to intervene'}</p>
          <small>{isZh ? '先判断对人的行为和业务结果会产生什么影响，再选择有成功可能的干预手段。' : 'First clarify the effect on behavior and outcomes, then choose an intervention with a realistic chance of working.'}</small>
        </aside>
      </section>

      <section class="v3-selected-work" aria-labelledby="selected-title" data-reveal>
        <header class="v3-section-heading">
          <div><span>02</span><p>Selected Work</p></div>
          <h2 id="selected-title">{isZh ? '用项目证明判断力与执行力' : 'Proof of judgment and execution'}</h2>
          <p>{isZh ? '每个案例先回答为什么值得做，再展开关键判断、动作、证据和边界。' : 'Each case starts with why it matters, then explains decisions, actions, evidence, and limits.'}</p>
        </header>

        <div class="v3-work-list">
          {selected.map((project, index) => project && (
            <a href={`${projectBase}/${project.slug}/`} class="v3-work-row" data-reveal>
              <span class="v3-work-number">0{index + 1}</span>
              <div class="v3-work-copy">
                <p>{project.eyebrow[lang]} · {project.year}</p>
                <h3>{project.displayTitle[lang]}</h3>
                <small>{project.title}</small>
                <p>{project.summary[lang]}</p>
              </div>
              <div class="v3-work-proof"><span>{isZh ? '关键证据' : 'Key proof'}</span><strong>{project.evidence[lang][0]}</strong></div>
              <b aria-hidden="true">↗</b>
            </a>
          ))}
        </div>
        <a class="v3-inline-link" href={workPath}>{isZh ? '进入完整 Work' : 'View all work'} <span>→</span></a>
      </section>

      <section class="v3-experience-band" aria-labelledby="experience-title" data-reveal>
        <div class="v3-experience-label"><span>03</span><p>{isZh ? '真实组织经历' : 'In an organization'}</p></div>
        <div class="v3-experience-copy">
          <p>{experience.date}</p>
          <h2 id="experience-title">{experience.title[lang]}</h2>
          <strong>{experience.place[lang]}</strong>
          <p>{experience.detail[lang]}</p>
        </div>
        <div class="v3-experience-proof">
          <strong>3 {isZh ? '天' : 'days'}</strong>
          <span>{isZh ? '完成道路变化修正与平台验证' : 'from road change to verified platform update'}</span>
          <a href={workPath}>{isZh ? '查看经历与项目' : 'Experience and cases'} ↗</a>
        </div>
      </section>

      <section class="v3-home-elsewhere" aria-label={isZh ? '更多内容' : 'More from Kylian'} data-reveal>
        <a href={interestsPath}><span>{isZh ? '兴趣作品' : 'Side Projects'}</span><h2>{isZh ? 'AIGC 漫剧与 Codex 桌宠' : 'AIGC film and a Codex desktop pet'}</h2><p>{isZh ? '主线之外，由好奇心驱动的制作。' : 'Curiosity-driven builds outside the main line.'}</p><b>↗</b></a>
        <a href={aboutPath}><span>{isZh ? '关于与观察' : 'About & Notes'}</span><h2>{isZh ? '教育背景、个人判断与 F1 Notes' : 'Education, point of view, and F1 Notes'}</h2><p>{isZh ? '同样理性，只是观察对象不同。' : 'The same analytical lens, applied elsewhere.'}</p><b>↗</b></a>
      </section>

      <section class="v3-contact" aria-labelledby="contact-title" data-reveal>
        <div><p class="v3-kicker">Contact</p><h2 id="contact-title">{isZh ? '如果你也在处理一个值得做、但还没有被说清的问题，欢迎联系我。' : 'If you are working on a problem worth solving but not yet clearly framed, get in touch.'}</h2></div>
        <div class="v3-contact-links">
          <a href={`mailto:${profile.email}`}><span>Email</span><strong>{profile.email}</strong><b>↗</b></a>
          <a href={profile.x.url} target="_blank" rel="noreferrer"><span>X</span><strong>{profile.x.label}</strong><b>↗</b></a>
        </div>
      </section>
    </main>
    <footer class="v3-footer"><p>© {new Date().getFullYear()} Kylian</p><p>{isZh ? '判断 · 执行 · 验证' : 'Judgment · Execution · Validation'}</p><a href="#content">{isZh ? '回到顶部' : 'Back to top'} ↑</a></footer>
  </div>
</BaseLayout>
