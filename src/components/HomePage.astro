---
import type { Lang } from '../data/content';
import { f1Notes, profile, projects, timeline } from '../data/content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from './SiteHeader.astro';

interface Props { lang: Lang }
const { lang } = Astro.props;
const isZh = lang === 'zh';
const home = isZh ? '/' : '/en/';
const projectBase = isZh ? '/projects' : '/en/projects';
const f1Path = isZh ? '/f1/' : '/en/f1/';
const alternate = isZh ? '/en/' : '/';
const title = isZh ? 'Kylian — 让复杂系统变得自然、可理解、可验证' : 'Kylian — Making complex systems intuitive, understandable, and verifiable';
const description = profile.intro[lang];
---

<BaseLayout lang={lang} title={title} description={description} canonicalPath={home} alternatePath={alternate}>
  <div class="page-shell">
    <SiteHeader lang={lang} alternatePath={alternate} />

    <main id="content">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-photo-wrap">
          <picture>
            <source media="(max-width: 720px)" srcset="/images/vienna-hero-960.webp" />
            <img class="hero-photo" src="/images/vienna-hero-1800.webp" alt={isZh ? 'Kylian 在维也纳一座金色大厅中侧身望向右方' : 'Kylian looking to the right inside a golden hall in Vienna'} width="1800" height="1200" fetchpriority="high" />
          </picture>
          <p class="photo-caption">Vienna · 2024</p>
        </div>
        <div class="hero-copy">
          <p class="kicker">Kylian / Portfolio</p>
          <h1 id="hero-title">{isZh ? <>在复杂与自然之间，<br /><em>寻找一条可验证的路。</em></> : <>Between complexity and intuition,<br /><em>I look for a verifiable path.</em></>}</h1>
          <p class="hero-intro">{profile.intro[lang]}</p>
          <p class="hero-aside">{profile.aside[lang]}</p>
          <a class="text-link" href="#work">{isZh ? '看我的工作' : 'Explore selected work'} <span aria-hidden="true">↓</span></a>
        </div>
      </section>

      <section class="section work-section" id="work" aria-labelledby="work-title">
        <div class="section-heading">
          <p class="section-index">01</p>
          <div>
            <p class="kicker">Selected Work</p>
            <h2 id="work-title">{isZh ? '把判断留在系统里' : 'Keeping judgment inside the system'}</h2>
          </div>
          <p class="section-note">{isZh ? '四个案例，来自产品、评估、空间计算与生成式创作。' : 'Four cases across product thinking, evaluation, spatial computing, and generative creation.'}</p>
        </div>

        <div class="project-index">
          {projects.map((project) => (
            <article class="project-row">
              <p class="project-number">{project.number}</p>
              <div class="project-main">
                <p class="project-meta">{project.eyebrow[lang]} · {project.year}</p>
                <h3><a href={`${projectBase}/${project.slug}/`}>{project.title}</a></h3>
                <p>{project.summary[lang]}</p>
              </div>
              <ul class="tag-list" aria-label={isZh ? '主题标签' : 'Topics'}>
                {project.tags.slice(0, 2).map((tag) => <li>{tag}</li>)}
              </ul>
              <a class="arrow-link" href={`${projectBase}/${project.slug}/`} aria-label={`${isZh ? '阅读案例' : 'Read case study'}: ${project.title}`}>↗</a>
            </article>
          ))}
        </div>
      </section>

      <section class="section f1-feature" aria-labelledby="f1-title">
        <div class="section-heading section-heading--inverse">
          <p class="section-index">02</p>
          <div>
            <p class="kicker">F1 Notes</p>
            <h2 id="f1-title">{isZh ? '速度之外，是一套被压缩的世界。' : 'Beyond speed is a compressed world.'}</h2>
          </div>
          <p class="section-note">{isZh ? '赛事 · 产业 · 技术' : 'Sport · Business · Technology'}</p>
        </div>
        <figure class="f1-photo-band">
          <picture>
            <source media="(max-width: 720px)" srcset="/images/f1-notes-960.webp" />
            <img src="/images/f1-notes-1800.webp" alt={isZh ? 'Kylian 拍摄的一辆经典方程式赛车' : 'A classic formula racing car photographed by Kylian'} width="1800" height="1200" loading="lazy" />
          </picture>
          <figcaption>{isZh ? '个人摄影 · 车型暂不标注' : 'Personal photograph · model intentionally unlabeled'}</figcaption>
        </figure>
        <div class="f1-statement">
          <p>{isZh ? '我关注 F1，不只是因为速度，也因为它把车手天赋、车队工程、商业利益与规则政治压缩在同一条赛道上。' : 'I follow F1 not only for speed, but because it compresses driver talent, team engineering, commercial interests, and regulatory politics onto the same track.'}</p>
        </div>
        <ol class="f1-preview-list">
          {f1Notes.map((note, index) => (
            <li>
              <span>{String(index + 1).padStart(2, '0')} / {note.category[lang]}</span>
              <a href={`${f1Path}#${note.id}`}>{note.title[lang]}</a>
            </li>
          ))}
        </ol>
        <a class="text-link text-link--light" href={f1Path}>{isZh ? '进入 F1 Notes' : 'Enter F1 Notes'} <span aria-hidden="true">→</span></a>
      </section>

      <section class="section timeline-section" id="about" aria-labelledby="about-title">
        <div class="section-heading">
          <p class="section-index">03</p>
          <div>
            <p class="kicker">Experience & Education</p>
            <h2 id="about-title">{isZh ? '我从哪里出发' : 'Where I started'}</h2>
          </div>
          <p class="section-note">{isZh ? '地图训练我尊重坐标与证据，Agent 让我重新理解不确定性。' : 'Maps taught me to respect coordinates and evidence; agents changed how I understand uncertainty.'}</p>
        </div>

        <div class="timeline-grid">
          <div>
            <h3>{isZh ? '经历' : 'Experience'}</h3>
            {timeline.experience.map((item) => (
              <article class="timeline-item">
                <time>{item.date}</time>
                <div><h4>{item.title[lang]}</h4><p class="place">{item.place[lang]}</p><p>{item.detail[lang]}</p></div>
              </article>
            ))}
          </div>
          <div>
            <h3>{isZh ? '教育' : 'Education'}</h3>
            {timeline.education.map((item) => (
              <article class="timeline-item timeline-item--compact">
                <time>{item.date}</time>
                <div><h4>{item.title[lang]}</h4><p class="place">{item.place[lang]}</p></div>
              </article>
            ))}
          </div>
        </div>

        <ul class="notes-strip">
          {timeline.notes.map((note) => (
            <li>{note.link ? <a href={note.link} target="_blank" rel="noreferrer">{note[lang]} ↗</a> : note[lang]}</li>
          ))}
        </ul>
      </section>

      <section class="contact-section" id="contact" aria-labelledby="contact-title">
        <p class="section-index">04</p>
        <div>
          <p class="kicker">Contact</p>
          <h2 id="contact-title">{isZh ? '如果你也在处理复杂问题，欢迎写信。' : 'If you are working through a complex problem, write to me.'}</h2>
          <a class="email-link" href={`mailto:${profile.email}`}>{profile.email}</a>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <p>© {new Date().getFullYear()} Kylian</p>
      <p>{isZh ? '以好奇心构建，以证据校正。' : 'Built with curiosity, corrected by evidence.'}</p>
      <a href="#content">{isZh ? '回到顶部 ↑' : 'Back to top ↑'}</a>
    </footer>
  </div>
</BaseLayout>
