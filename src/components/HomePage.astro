---
import type { Lang } from '../data/content';
import { profile, projects } from '../data/content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from './SiteHeader.astro';

interface Props { lang: Lang }
const { lang } = Astro.props;
const isZh = lang === 'zh';
const home = isZh ? '/' : '/en/';
const workPath = isZh ? '/work/' : '/en/work/';
const aboutPath = isZh ? '/about/' : '/en/about/';
const f1Path = isZh ? '/f1/' : '/en/f1/';
const projectBase = isZh ? '/projects' : '/en/projects';
const alternate = isZh ? '/en/' : '/';
const title = isZh ? 'Kylian — 复杂系统的探索者' : 'Kylian — Explorer of complex systems';
const description = profile.intro[lang];
const selected = projects.slice(0, 2);
---

<BaseLayout lang={lang} title={title} description={description} canonicalPath={home} alternatePath={alternate}>
  <div class="page-shell">
    <SiteHeader lang={lang} alternatePath={alternate} />
    <main id="content">
      <section class="home-hero" aria-labelledby="hero-title">
        <div class="home-hero-photo">
          <picture>
            <source media="(max-width: 720px)" srcset="/images/vienna-hero-960.webp" />
            <img src="/images/vienna-hero-1800.webp" alt={isZh ? 'Kylian 在维也纳一座金色大厅中侧身望向右方' : 'Kylian looking to the right inside a golden hall in Vienna'} width="1800" height="1200" fetchpriority="high" />
          </picture>
          <p>Vienna · 2024 / {isZh ? '个人摄影' : 'Personal photograph'}</p>
        </div>
        <div class="home-hero-copy">
          <div class="gold-rule"><span>Portfolio / 2026</span></div>
          <p class="kicker">Quiet Explorer</p>
          <h1 id="hero-title">{isZh ? <>让复杂系统<br /><em>自然发生。</em></> : <>Making complex systems<br /><em>feel natural.</em></>}</h1>
          <p class="home-hero-intro">{profile.intro[lang]}</p>
          <div class="hero-direction">
            <span>{isZh ? '当前关注' : 'Current focus'}</span>
            <p>{isZh ? '产品判断 · Agent 可靠性 · 创作流程' : 'Product judgment · Agent reliability · Creative workflows'}</p>
          </div>
        </div>
      </section>

      <section class="chapter-index" aria-labelledby="chapters-title">
        <header>
          <p class="section-index">Index</p>
          <div><p class="kicker">Three chapters</p><h2 id="chapters-title">{isZh ? '从这里选择一条路径' : 'Choose a path from here'}</h2></div>
        </header>
        <div class="chapter-links">
          <a href={workPath}><span>01</span><div><p>{isZh ? '工作' : 'Work'}</p><h3>{isZh ? '复杂问题如何被拆解和验证' : 'How complex problems are framed and verified'}</h3></div><b>↗</b></a>
          <a href={aboutPath}><span>02</span><div><p>{isZh ? '关于' : 'About'}</p><h3>{isZh ? '经历、教育与我的工作方式' : 'Experience, education, and how I work'}</h3></div><b>↗</b></a>
          <a href={f1Path}><span>03</span><div><p>F1 Notes</p><h3>{isZh ? '赛事、产业与技术的长期短札' : 'Durable notes on sport, business, and technology'}</h3></div><b>↗</b></a>
        </div>
      </section>

      <section class="home-selected" aria-labelledby="selected-title">
        <div class="home-section-title">
          <div><p class="kicker">Selected Work</p><h2 id="selected-title">{isZh ? '最近的两个判断' : 'Two recent judgments'}</h2></div>
          <a class="text-link" href={workPath}>{isZh ? '查看全部工作' : 'View all work'} →</a>
        </div>
        <div class="home-projects">
          {selected.map((project) => (
            <a href={`${projectBase}/${project.slug}/`}>
              <span>{project.number} / {project.year}</span>
              <p>{project.eyebrow[lang]}</p>
              <h3>{project.title}</h3>
              <div><p>{project.summary[lang]}</p><b>↗</b></div>
            </a>
          ))}
        </div>
      </section>

      <section class="home-contact" aria-labelledby="contact-title">
        <span class="gold-orbit" aria-hidden="true"></span>
        <div><p class="kicker">Contact</p><h2 id="contact-title">{isZh ? '有一个复杂问题？我们可以从一封邮件开始。' : 'Have a complex problem? We can start with an email.'}</h2></div>
        <div class="home-contact-links">
          <a href={`mailto:${profile.email}`}><span>Email</span>{profile.email} ↗</a>
          <a href={profile.x.url} target="_blank" rel="noreferrer"><span>X</span>{profile.x.label} ↗</a>
        </div>
      </section>
    </main>
    <footer class="site-footer"><p>© {new Date().getFullYear()} Kylian</p><p>{isZh ? '以好奇心构建，以证据校正。' : 'Built with curiosity, corrected by evidence.'}</p><a href="#content">{isZh ? '回到顶部 ↑' : 'Back to top ↑'}</a></footer>
  </div>
</BaseLayout>
