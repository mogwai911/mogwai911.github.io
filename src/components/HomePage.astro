---
import type { Lang } from '../data/content';
import { profile, projects } from '../data/content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from './SiteHeader.astro';

interface Props { lang: Lang }
const { lang } = Astro.props;
const isZh = lang === 'zh';
const home = isZh ? '/' : '/en/';
const workPath = isZh ? '/work/' : '/en/work/';
const aboutPath = isZh ? '/about/' : '/en/about/';
const hobbiesPath = isZh ? '/hobbies/' : '/en/hobbies/';
const projectBase = isZh ? '/projects' : '/en/projects';
const alternate = isZh ? '/en/' : '/';
const title = isZh ? 'Kylian — AI 应用、评测与 GIS 项目' : 'Kylian — AI applications, evaluation, and GIS';
const description = profile.intro[lang];
const selected = projects.slice(0, 2);
---

<BaseLayout lang={lang} title={title} description={description} canonicalPath={home} alternatePath={alternate}>
  <div class="page-shell">
    <SiteHeader lang={lang} alternatePath={alternate} />
    <main id="content">
      <section class="home-hero" aria-labelledby="hero-title">
        <div class="home-hero-photo">
          <picture>
            <source media="(max-width: 720px)" srcset="/images/vienna-hero-960.webp" />
            <img src="/images/vienna-hero-1800.webp" alt={isZh ? 'Kylian 在维也纳一座金色大厅中侧身望向右方' : 'Kylian looking to the right inside a golden hall in Vienna'} width="1800" height="1200" fetchpriority="high" />
          </picture>
          <p>Vienna · 2024 / {isZh ? '个人摄影' : 'Personal photograph'}</p>
        </div>
        <div class="home-hero-copy">
          <div class="gold-rule"><span>Portfolio / 2026</span></div>
          <p class="kicker">Product · AI workflows · GIS</p>
          <h1 id="hero-title">{isZh ? <>把复杂问题，<br /><em>做成可验证的工具。</em></> : <>Turn complex problems<br /><em>into verifiable tools.</em></>}</h1>
          <p class="home-hero-intro">{profile.intro[lang]}</p>
          <div class="hero-direction">
            <span>{isZh ? '我的方法' : 'My approach'}</span>
            <p>{isZh ? '先说明问题为什么值得做，再拆流程、做验证、讲清边界。' : 'Explain why the problem matters, then design the workflow, validate the result, and state the boundary.'}</p>
          </div>
        </div>
      </section>

      <section class="chapter-index" aria-labelledby="chapters-title">
        <header>
          <p class="section-index">Index</p>
          <div><p class="kicker">Three sections</p><h2 id="chapters-title">{isZh ? '网站内容导航' : 'Explore the site'}</h2></div>
        </header>
        <div class="chapter-links">
          <a href={workPath}><span>01</span><div><p>{isZh ? '工作' : 'Work'}</p><h3>{isZh ? '四个案例：问题价值、关键决策、具体动作与结果证据' : 'Four cases: problem value, key decisions, actions, and evidence'}</h3></div><b>↗</b></a>
          <a href={aboutPath}><span>02</span><div><p>{isZh ? '关于' : 'About'}</p><h3>{isZh ? '实习、教育背景、奖项与联系方式' : 'Experience, education, awards, and contact details'}</h3></div><b>↗</b></a>
          <a href={hobbiesPath}><span>03</span><div><p>{isZh ? '爱好' : 'Hobbies'}</p><h3>{isZh ? 'F1 赛事、产业与技术短札，以及个人摄影' : 'Notes on F1 sport, business, and technology, plus personal photography'}</h3></div><b>↗</b></a>
        </div>
      </section>

      <section class="home-selected" aria-labelledby="selected-title">
        <div class="home-section-title">
          <div><p class="kicker">Selected Work</p><h2 id="selected-title">{isZh ? '重点案例' : 'Featured cases'}</h2></div>
          <a class="text-link" href={workPath}>{isZh ? '查看全部工作' : 'View all work'} →</a>
        </div>
        <div class="home-projects">
          {selected.map((project) => (
            <a href={`${projectBase}/${project.slug}/`}>
              <span>{project.number} / {project.year}</span>
              <p>{project.eyebrow[lang]}</p>
              <h3>{project.displayTitle[lang]}</h3>
              <p class="project-codename">{project.title}</p>
              <div><p>{project.summary[lang]}</p><b>↗</b></div>
            </a>
          ))}
        </div>
      </section>

      <section class="home-contact" aria-labelledby="contact-title">
        <span class="gold-orbit" aria-hidden="true"></span>
        <div><p class="kicker">Contact</p><h2 id="contact-title">{isZh ? '想聊 AI 工作流、数据质量或产品验证，欢迎联系我。' : 'For conversations about AI workflows, data quality, or product validation, get in touch.'}</h2></div>
        <div class="home-contact-links">
          <a href={`mailto:${profile.email}`}><span>Email</span>{profile.email} ↗</a>
          <a href={profile.x.url} target="_blank" rel="noreferrer"><span>X</span>{profile.x.label} ↗</a>
        </div>
      </section>
    </main>
    <footer class="site-footer"><p>© {new Date().getFullYear()} Kylian</p><p>{isZh ? '问题定义 · 流程拆解 · 结果验证' : 'Problem framing · Workflow design · Result validation'}</p><a href="#content">{isZh ? '回到顶部 ↑' : 'Back to top ↑'}</a></footer>
  </div>
</BaseLayout>
