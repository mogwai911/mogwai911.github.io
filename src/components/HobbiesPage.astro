---
import type { Lang } from '../data/content';
import { projects } from '../data/content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from './SiteHeader.astro';

interface Props { lang: Lang }
const { lang } = Astro.props;
const isZh = lang === 'zh';
const canonicalPath = isZh ? '/hobbies/' : '/en/hobbies/';
const alternatePath = isZh ? '/en/hobbies/' : '/hobbies/';
const petPath = isZh ? '/pet/' : '/en/pet/';
const projectBase = isZh ? '/projects' : '/en/projects';
const aigc = projects.find((project) => project.slug === 'aigc-pov')!;
const description = isZh ? 'Kylian 的兴趣制作：AIGC 多镜头影像与 Codex 桌宠。' : 'Kylian’s side projects: multi-shot AIGC film and a Codex desktop pet.';
---

<BaseLayout lang={lang} title={`${isZh ? '兴趣制作' : 'Side projects'} — Kylian`} description={description} canonicalPath={canonicalPath} alternatePath={alternatePath}>
  <div class="site-shell side-shell">
    <SiteHeader lang={lang} alternatePath={alternatePath} compact />
    <main id="content">
      <header class="simple-hero content-width side-hero" data-reveal>
        <p class="section-label">Made by curiosity</p>
        <h1>{isZh ? <>有些想法，<br /><em>只是很想看它出现。</em></> : <>Some ideas simply<br /><em>ask to be made visible.</em></>}</h1>
        <p>{isZh ? '这两件东西不属于 Work，也没有被包装成职业能力。一个来自对连续影像的好奇，一个来自对工具陪伴感的好奇。' : 'These two pieces do not belong under Work, and they are not dressed up as career proof. One came from curiosity about continuous images; the other from curiosity about companionship in tools.'}</p>
      </header>

      <section class="side-feature side-feature--film content-width" data-reveal>
        <figure>
          <img src="/images/aigc-pov.webp" alt={aigc.images?.[0]?.alt[lang]} width="1600" height="900" />
          <figcaption>AIGC POV · 2025–26</figcaption>
        </figure>
        <div>
          <p class="section-label">A film made in fragments</p>
          <h2>{aigc.displayTitle[lang]}</h2>
          <p>{isZh ? '我想知道：当角色、镜头和动作被拆成很多次生成，怎样才能让观众仍然相信它们属于同一段经历？于是我把提示词、角色约束和镜头衔接整理成一套可以重复修改的制作方法。' : 'I wanted to know how viewers could still believe that separate generations—characters, shots, and actions—belonged to one continuous experience. I turned prompts, character constraints, and shot transitions into a method that could be revised rather than blindly rerolled.'}</p>
          <div class="side-feature__actions">
            <a class="button-link" href={`${projectBase}/${aigc.slug}/`}>{isZh ? '看它是怎么做出来的' : 'See how it was made'} <span>↗</span></a>
            {aigc.video && <a class="quiet-link" href={aigc.video.url} target="_blank" rel="noreferrer" title={aigc.video.title[lang]}>{isZh ? '在 Bilibili 看成片' : 'Watch the finished film'} <span>↗</span></a>}
          </div>
        </div>
      </section>

      <section class="side-feature side-feature--pet content-width" data-reveal>
        <div class="pet-window">
          <div
            class="pet-avatar"
            role="img"
            aria-label={isZh ? '陈千语桌宠的待机动画' : 'Chen Qianyu desktop pet idle animation'}
          ></div>
          <p class="pet-window__meta"><span>CHEN QIANYU · IDLE</span><span>PETDEX NO. 3379</span></p>
        </div>
        <div>
          <p class="section-label">A small companion</p>
          <h2>{isZh ? '陈千语，一只陪 Agent 等待的 Codex 桌宠' : 'Chen Qianyu, a Codex pet for the moments between tasks'}</h2>
          <p>{isZh ? '等待 Agent 完成任务通常只剩一个进度状态。我想让这段时间多一点生命感，于是把任务状态、等待和反馈做成一只会变化的桌面角色。它没有宏大价值，只是确实让我想把它做出来。' : 'Waiting for an agent usually collapses into a progress state. I wanted that time to feel a little more alive, so I turned task status, waiting, and feedback into a changing desktop character. It has no grand value claim; I simply wanted it to exist.'}</p>
          <div class="side-feature__actions">
            <a class="button-link" href={petPath}>{isZh ? '直接在线打开' : 'Open in browser'} <span>↗</span></a>
            <a class="quiet-link" href="https://petdex.dev/pets/chen-qianyu-3" target="_blank" rel="noreferrer">{isZh ? '在 PetDex 看她' : 'Meet her on PetDex'} <span>→</span></a>
          </div>
        </div>
      </section>

      <nav class="next-note content-width" aria-label={isZh ? '继续浏览' : 'Continue browsing'}>
        <p>{isZh ? '教育背景、正在关心的问题和 F1 Notes 放在 About。' : 'Education, current interests, and F1 Notes live in About.'}</p>
        <a class="quiet-link" href={isZh ? '/about/' : '/en/about/'}>{isZh ? '去 About' : 'Go to About'} <span>→</span></a>
      </nav>
    </main>
    <footer class="site-footer content-width"><p>© {new Date().getFullYear()} Kylian</p><p>Side projects</p><a href="#content">{isZh ? '回到顶部' : 'Back to top'} ↑</a></footer>
  </div>
</BaseLayout>
