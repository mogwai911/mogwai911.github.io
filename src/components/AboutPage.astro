---
import type { Lang } from '../data/content';
import { profile, timeline } from '../data/content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from './SiteHeader.astro';

interface Props { lang: Lang }
const { lang } = Astro.props;
const isZh = lang === 'zh';
const canonicalPath = isZh ? '/about/' : '/en/about/';
const alternatePath = isZh ? '/en/about/' : '/about/';
const description = isZh ? '关于 Kylian：从 GIS 到 Agent 与创作工具的经历、教育和工作方式。' : 'About Kylian: background, education, and approach from GIS to agents and creative tools.';
---

<BaseLayout lang={lang} title={`${isZh ? '关于' : 'About'} — Kylian`} description={description} canonicalPath={canonicalPath} alternatePath={alternatePath}>
  <div class="page-shell">
    <SiteHeader lang={lang} alternatePath={alternatePath} compact />
    <main id="content" class="about-page">
      <header class="about-hero">
        <div class="about-portrait">
          <picture><source media="(max-width: 720px)" srcset="/images/vienna-hero-960.webp" /><img src="/images/vienna-hero-1800.webp" alt={isZh ? 'Kylian 在维也纳一座金色大厅中' : 'Kylian inside a golden hall in Vienna'} width="1800" height="1200" /></picture>
          <p>02 / About · Vienna</p>
        </div>
        <div class="about-intro">
          <div class="gold-rule"><span>{isZh ? '关于这个人' : 'About this person'}</span></div>
          <p class="kicker">GIS · AI applications · Evaluation</p>
          <h1>{isZh ? <>GIS 背景，<br /><em>AI 应用与评测实践。</em></> : <>A GIS background,<br /><em>with AI application and evaluation work.</em></>}</h1>
          <p>{isZh ? '我的项目集中在三类工作：把专业数据组织成可用输入，把 AI 输出接入可执行流程，以及用证据和指标定位失败。相比堆叠模型名，我更愿意说明每项技术解决什么问题、如何验证。' : 'My work centers on three tasks: organizing specialist data into usable inputs, connecting AI output to executable workflows, and diagnosing failure with evidence and metrics. I would rather explain what each technology solves and how it is validated than list model names.'}</p>
        </div>
      </header>

      <section class="about-timeline" aria-labelledby="journey-title">
        <header><p class="section-index">Journey</p><h2 id="journey-title">{isZh ? '经历与教育' : 'Experience & education'}</h2><p>{isZh ? '这里保留公开所需的经历、教育和可核验成果，不提供完整简历下载。' : 'This page keeps the public background, education, and verifiable outcomes needed here; no full résumé download is provided.'}</p></header>
        <div class="timeline-grid">
          <div><h3>{isZh ? '经历' : 'Experience'}</h3>{timeline.experience.map((item) => <article class="timeline-item"><time>{item.date}</time><div><h4>{item.title[lang]}</h4><p class="place">{item.place[lang]}</p><p>{item.detail[lang]}</p></div></article>)}</div>
          <div><h3>{isZh ? '教育' : 'Education'}</h3>{timeline.education.map((item) => <article class="timeline-item timeline-item--compact"><time>{item.date}</time><div><h4>{item.title[lang]}</h4><p class="place">{item.place[lang]}</p></div></article>)}</div>
        </div>
      </section>

      <section class="about-notes" aria-labelledby="notes-title">
        <header><p class="section-index">Additional</p><h2 id="notes-title">{isZh ? '其他信息' : 'Other details'}</h2></header>
        <ul>{timeline.notes.map((note, index) => <li><span>{String(index + 1).padStart(2, '0')}</span>{note.link ? <a href={note.link} target="_blank" rel="noreferrer">{note[lang]} ↗</a> : <p>{note[lang]}</p>}</li>)}</ul>
      </section>

      <section class="about-contact" aria-labelledby="about-contact-title">
        <div><p class="kicker">Contact</p><h2 id="about-contact-title">{isZh ? '如果你正在处理一个难以说清的问题，欢迎来信。' : 'If you are working on a problem that is hard to articulate, write to me.'}</h2></div>
        <div class="contact-list"><a href={`mailto:${profile.email}`}><span>Email</span>{profile.email} ↗</a>{profile.x && <a href={profile.x.url} target="_blank" rel="noreferrer"><span>X</span>{profile.x.label} ↗</a>}</div>
      </section>
    </main>
    <footer class="site-footer"><p>© {new Date().getFullYear()} Kylian</p><p>About / 02</p><a href="#content">{isZh ? '回到顶部 ↑' : 'Back to top ↑'}</a></footer>
  </div>
</BaseLayout>
