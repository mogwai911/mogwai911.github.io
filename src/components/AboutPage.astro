---
import type { Lang } from '../data/content';
import { profile, timeline } from '../data/content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from './SiteHeader.astro';

interface Props { lang: Lang }
const { lang } = Astro.props;
const isZh = lang === 'zh';
const canonicalPath = isZh ? '/about/' : '/en/about/';
const alternatePath = isZh ? '/en/about/' : '/about/';
const hobbiesPath = isZh ? '/hobbies/' : '/en/hobbies/';
const description = isZh ? '关于 Kylian：空间数据背景、正在做的事与教育经历。' : 'About Kylian: a spatial-data background, current work, and education.';
---

<BaseLayout lang={lang} title={`${isZh ? '关于' : 'About'} — Kylian`} description={description} canonicalPath={canonicalPath} alternatePath={alternatePath}>
  <div class="site-shell about-shell">
    <SiteHeader lang={lang} alternatePath={alternatePath} compact />
    <main id="content">
      <header class="about-portrait content-width" data-reveal>
        <figure>
          <picture><source media="(max-width: 720px)" srcset="/images/vienna-hero-960.webp" /><img src="/images/vienna-hero-1800.webp" alt={isZh ? 'Kylian 在金色大厅中侧身看向右方' : 'Kylian looking to the right inside a golden hall'} width="1800" height="1200" /></picture>
          <figcaption>{isZh ? '旅行时，我更喜欢先看一会儿。' : 'When travelling, I prefer to watch for a while.'}</figcaption>
        </figure>
        <div>
          <p class="section-label">About Kylian</p>
          <h1>{isZh ? <>我对未知有耐心，<br /><em>对含糊没有。</em></> : <>I am patient with the unknown,<br /><em>but not with vagueness.</em></>}</h1>
          <p>{isZh ? '我喜欢先观察一个系统怎么运转，再找到能让它变清楚、变可靠的那个切口。GIS 教会我尊重现实世界的复杂性；做 Agent 和 AI 应用，则让我更在意失败、证据与人的最终判断。' : 'I like to watch how a system behaves before finding the opening that can make it clearer and more reliable. GIS taught me to respect real-world complexity; building agents and AI applications made me care more about failure, evidence, and the final human judgment.'}</p>
          <p>{isZh ? '工作之外，我会拍照、看 F1，也会把一个不太实用但很想看到的想法做出来。' : 'Outside work, I take photographs, follow F1, and sometimes build an idea simply because I want to see it exist.'}</p>
        </div>
      </header>

      <section class="about-now content-width" data-reveal>
        <p class="section-label">{isZh ? '我现在关心的事' : 'What I care about now'}</p>
        <div>
          <h2>{isZh ? 'AI 不缺“能做”，更缺“为什么做”和“怎么知道做对了”。' : 'AI has plenty of “can do.” It needs more “why” and “how do we know it worked.”'}</h2>
          <p>{isZh ? '所以我会把时间放在应用落地、Agent 评测与工作流产品上：让模型进入一个具体任务，让失败可以被定位，让改动能被真实行为或结果验证。' : 'That is why I spend time on AI applications, agent evaluation, and workflow products: putting models into concrete tasks, making failure diagnosable, and verifying change through real behavior or outcomes.'}</p>
        </div>
      </section>

      <section class="education-lines content-width" data-reveal>
        <div class="education-lines__intro">
          <header><p class="section-label">Background</p><h2>{isZh ? '空间数据，是我理解复杂系统的起点。' : 'Spatial data was my starting point for understanding complex systems.'}</h2></header>
          <figure class="education-evidence">
            <picture><source media="(max-width: 720px)" srcset="/images/lund-presentation-960.webp" /><img src="/images/lund-presentation-1800.webp" alt={isZh ? 'Kylian 在课堂展示多 Agent 实验平台' : 'Kylian presenting a multi-agent experimental platform in class'} width="1800" height="1350" loading="lazy" /></picture>
            <figcaption>{isZh ? '硕士项目展示 · 多 Agent 实验平台' : 'MSc project presentation · Multi-agent experimental platform'}</figcaption>
          </figure>
        </div>
        <div class="education-lines__list">
          {timeline.education.map((item) => (
            <article><time>{item.date}</time><h3>{item.title[lang]}</h3><p>{item.place[lang]}</p></article>
          ))}
        </div>
      </section>

      <nav class="next-note content-width" aria-label={isZh ? '继续浏览' : 'Continue browsing'} data-reveal>
        <p>{isZh ? '工作之外的 F1、AIGC 和桌宠放在 Hobbies。' : 'F1, AIGC, and the Codex pet live in Hobbies.'}</p>
        <a class="quiet-link" href={hobbiesPath}>{isZh ? '去看兴趣' : 'Explore hobbies'} <span>→</span></a>
      </nav>

      <section class="contact-note content-width" data-reveal>
        <div class="contact-note__copy">
          <p class="section-label">Open to work · Open to conversation</p>
          <h2>{isZh ? '我在寻找新的工作机会，也愿意随便聊聊。' : 'I’m open to new roles—and always happy to have a real conversation.'}</h2>
          <p>{isZh ? '工作、合作、一个还没想清楚的点子，或者只是想打个招呼，都欢迎来找我。' : 'Work, collaboration, an unfinished idea, or simply saying hello—you are welcome to reach out.'}</p>
        </div>
        <div class="contact-note__actions">
          <a class="contact-link" href={`mailto:${profile.email}`}><span>Email</span><strong>{profile.email}</strong><i aria-hidden="true">↗</i></a>
          <a class="contact-link" href={profile.x.url} target="_blank" rel="noreferrer"><span>X</span><strong>{profile.x.label}</strong><i aria-hidden="true">↗</i></a>
        </div>
      </section>
    </main>
    <footer class="site-footer content-width"><p>© {new Date().getFullYear()} Kylian</p><p>About</p><a href="#content">{isZh ? '回到顶部' : 'Back to top'} ↑</a></footer>
  </div>
</BaseLayout>
