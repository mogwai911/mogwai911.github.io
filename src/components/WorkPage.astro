---
import type { Lang } from '../data/content';
import { projects, timeline } from '../data/content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from './SiteHeader.astro';

interface Props { lang: Lang }
const { lang } = Astro.props;
const isZh = lang === 'zh';
const canonicalPath = isZh ? '/work/' : '/en/work/';
const alternatePath = isZh ? '/en/work/' : '/work/';
const projectBase = isZh ? '/projects' : '/en/projects';
const description = isZh ? 'Kylian 的 AI 应用、Agent 评测与 GIS 项目记录。' : 'Kylian’s project notes on AI applications, agent evaluation, and GIS.';
const workOrder = ['tb2-diagnostics', 'fomo-firewall', 'geoagent'];
const workProjects = workOrder.map((slug) => projects.find((project) => project.slug === slug)).filter(Boolean);
const posterLabels = {
  'tb2-diagnostics': ['TRACE', 'CAUSE', 'FIX'],
  'fomo-firewall': ['LEARN', 'LATER', 'IGNORE'],
  'geoagent': ['SEARCH', 'RUN', 'VERIFY'],
};
---

<BaseLayout lang={lang} title={`${isZh ? '作品' : 'Work'} — Kylian`} description={description} canonicalPath={canonicalPath} alternatePath={alternatePath}>
  <div class="site-shell work-shell">
    <SiteHeader lang={lang} alternatePath={alternatePath} compact />
    <main id="content">
      <header class="simple-hero content-width" data-reveal>
        <p class="section-label">Work / selected cases</p>
        <h1>{isZh ? <>这些是我真正<br /><em>花时间做过的事。</em></> : <>These are the things<br /><em>I genuinely spent time making.</em></>}</h1>
        <p>{isZh ? '面对 Agent 日志、信息过载或 GIS 代码，我会先找到真正阻塞结果的环节，再决定该做流程、评测还是工具。下面三个案例记录了这个过程。' : 'Across agent traces, information overload, and GIS code, I start by locating what actually blocks the outcome. Then I decide whether the answer is a workflow, an evaluation, or a tool. These three cases document that process.'}</p>
      </header>

      <section class="work-journal content-width" aria-label={isZh ? '项目案例' : 'Case studies'}>
        {workProjects.map((project) => project && (
          <article class={`work-entry work-entry--${project.slug}`} data-reveal>
            <a class="work-entry__poster project-poster" href={`${projectBase}/${project.slug}/`} aria-label={`${isZh ? '阅读案例' : 'Read case'}: ${project.displayTitle[lang]}`}>
              <div class="poster-grain"></div>
              <span class="poster-code">{project.title}</span>
              <div class="poster-orbit"><i></i><i></i><i></i></div>
              <div class="poster-words">{(posterLabels[project.slug as keyof typeof posterLabels] ?? []).map((word) => <span>{word}</span>)}</div>
            </a>
            <div class="work-entry__copy">
              <p class="entry-meta">{project.eyebrow[lang]} · {project.year}</p>
              <h2><a href={`${projectBase}/${project.slug}/`}>{project.displayTitle[lang]}</a></h2>
              <p class="entry-codename">{project.title}</p>
              <p>{project.summary[lang]}</p>
              <p class="entry-value"><span>{isZh ? '为什么值得做' : 'Why it matters'}</span>{project.value[lang]}</p>
              <p class="entry-role"><span>{isZh ? '我在里面做了什么' : 'What I worked on'}</span>{project.role[lang]}</p>
              <a class="button-link" href={`${projectBase}/${project.slug}/`}>{isZh ? '阅读完整案例' : 'Read the full case'} <span>↗</span></a>
            </div>
          </article>
        ))}
      </section>

      <section class="experience-note content-width" data-reveal>
        <p class="section-label">Field experience</p>
        <div>
          <time>{timeline.experience[0].date}</time>
          <h2>{timeline.experience[0].title[lang]}</h2>
          <p class="entry-codename">{timeline.experience[0].place[lang]}</p>
        </div>
        <p>{timeline.experience[0].detail[lang]}</p>
      </section>

      <nav class="next-note content-width" aria-label={isZh ? '继续浏览' : 'Continue browsing'}>
        <p>{isZh ? '主线之外，还有一些只是因为好奇而做的东西。' : 'Outside this main line are things made simply from curiosity.'}</p>
        <a class="quiet-link" href={isZh ? '/hobbies/' : '/en/hobbies/'}>{isZh ? '去看兴趣' : 'Explore hobbies'} <span>→</span></a>
      </nav>
    </main>
    <footer class="site-footer content-width"><p>© {new Date().getFullYear()} Kylian</p><p>Work</p><a href="#content">{isZh ? '回到顶部' : 'Back to top'} ↑</a></footer>
  </div>
</BaseLayout>
